# Mongo connection
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=poe_gateway

# Used to encrypt account credentials in Mongo.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=inHNYVtJy_3PgVPhgJCaJnyGSrTka8agGip6fsfg1lA=

# Admin API key: only for /admin/accounts/upsert and /admin/accounts
ADMIN_API_KEY=adm_9f1d3e0b1c8a4f4e9a7d_zaiwen

# Service API keys (comma-separated) used by OpenAI-compatible business endpoints.
# Example:
# Authorization: Bearer svc_key_1
SERVICE_API_KEYS_BOOTSTRAP=svc_app_zaiwen


# Gateway-level default Poe revision (可选).
# 若不填写，服务启动时将自动从 https://poe.com/login 页面解析最新值。
# Account-level `poe_revision` (from /admin/accounts/upsert) overrides this.
# POE_REVISION=

DAILY_RESET_TIMEZONE=America/Los_Angeles
DAILY_RESET_HOUR=0
DAILY_RESET_POINT_BALANCE=3000


# Optional tuning
MAX_INFLIGHT_PER_ACCOUNT=2
GLOBAL_INFLIGHT_LIMIT=200
DEPLETED_THRESHOLD=20
REFRESH_INTERVAL_SECONDS=600
RECENT_ACTIVE_MINUTES=120
COOLDOWN_SECONDS=120

# Auto-recover invalid accounts in small periodic batches
INVALID_AUTO_REFRESH_ENABLED=true
INVALID_AUTO_REFRESH_INTERVAL_SECONDS=900
INVALID_AUTO_REFRESH_BATCH_LIMIT=20
PREWARM_CONCURRENCY=5
PREWARM_MAX_ACCOUNTS=100
# Prewarm policy:
# - Build total queue by Mongo storage order (_id ASC)
# - Only prewarm accounts with balance >= current DB median
# - Reconnect-exhausted / TTL-expired accounts move to queue tail
# PREWARM_ON_STARTUP=false
# PREWARM_ACCOUNT_TIMEOUT_SECONDS=60
# AUTO_FETCH_POE_REVISION=false
# Rolling refresh: every 2 minutes recycle a small idle batch, then refill with newer warm clients
# PREWARM_ROLLING_REFRESH_ENABLED=true
# PREWARM_ROLLING_REFRESH_INTERVAL_SECONDS=120
# PREWARM_ROLLING_REFRESH_BATCH_SIZE=10
# PREWARM_ROLLING_REFRESH_REUSE_COOLDOWN_SECONDS=600
